{
    "name": "asharif88/filament-plotly",
    "description": "Inspired by https://filamentphp.com/plugins/leandrocfe-apex-charts & https://filamentphp.com/plugins/elemind-echarts this plugin delivers plotly.js integration for Filament.",
    "keywords": [
        "laravel",
        "filamentphp",
        "Plotly.js",
        "Filament Widgets",
        "filament-plotly",
        "Ahmad SHARIF",
        "Asharif88"
    ],
    "homepage": "https://github.com/asharif88/filament-plotly",
    "support": {
        "issues": "https://github.com/asharif88/filament-plotly/issues",
        "source": "https://github.com/asharif88/filament-plotly"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Ahmad SHARIF <Asharif88>",
            "email": "asharif88@proton.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^4.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^12.5.0",
        "orchestra/testbench": "^10.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Asharif88\\FilamentPlotly\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Asharif88\\FilamentPlotly\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Asharif88\\FilamentPlotly\\FilamentPlotlyServiceProvider"
            ],
            "aliases": {
                "FilamentPlotly": "Asharif88\\FilamentPlotly\\Facades\\FilamentPlotly"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}